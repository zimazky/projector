{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "prettier-check",
      "type": "shell",
      "command": "npx prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "prettier-fix",
      "type": "shell",
      "command": "npx prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}